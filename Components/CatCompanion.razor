@implements IAsyncDisposable
@inject IJSRuntime JS

@* Cozy cats that wander behind the whole page. The AI state machine
   (Walking / Sitting / Grooming / Sleeping) and random-walk pathing run in C#
   on a low-frame-rate loop. Click-and-hold anywhere to make them follow the
   cursor; click a cat to pet it (it purrs and its eyes glow). *@
<div class="cat-layer" aria-hidden="true">
    @foreach (var c in _cats)
    {
        <div class="cat-sprite cat-@c.State.ToString().ToLower() @(c.Happy ? "cat-happy" : "")"
             style="transform: translate(@Px(c.X - 34), @Px(c.Y - 30)) scaleX(@c.Facing);@PaletteVars(c)"
             @onclick="() => Pet(c)" @onclick:stopPropagation="true">

            <svg class="cat-svg" viewBox="0 0 100 100" width="68" height="60">
                <!-- Tail (sways) -->
                <g class="cat-tail">
                    <path class="s-body" d="M24 62 Q 6 58 12 40" stroke-width="6"
                          stroke-linecap="round" fill="none" />
                </g>

                <!-- Legs -->
                <rect class="cat-leg cat-leg-back f-body" x="30" y="70" width="6" height="9" rx="3" />
                <rect class="cat-leg cat-leg-front f-body" x="54" y="70" width="6" height="9" rx="3" />

                <!-- Body -->
                <rect class="f-body" x="22" y="46" width="48" height="28" rx="13" />

                <!-- Head group -->
                <g class="cat-head">
                    <path class="f-ear" d="M60 42 L66 24 L75 42 Z" />
                    <path class="f-ear" d="M77 42 L86 24 L93 42 Z" />
                    <rect class="f-body" x="58" y="38" width="36" height="30" rx="12" />

                    @if (c.State == CatState.Sleeping)
                    {
                        <path class="s-eye" d="M68 52 q4 4 8 0" stroke-width="2.5" stroke-linecap="round" fill="none" />
                        <path class="s-eye" d="M82 52 q4 4 8 0" stroke-width="2.5" stroke-linecap="round" fill="none" />
                    }
                    else
                    {
                        <circle class="cat-eye" cx="72" cy="52" r="3.4" />
                        <circle class="cat-eye" cx="86" cy="52" r="3.4" />
                    }

                    <path class="f-heart" d="M77 58 L83 58 L80 62 Z" />
                </g>

                @if (c.State == CatState.Sleeping)
                {
                    <g class="cat-zzz" font-family="monospace" font-weight="700">
                        <text x="92" y="30" font-size="9">z</text>
                        <text x="98" y="22" font-size="11">z</text>
                    </g>
                }
            </svg>

            <!-- Purr heart, shown while being petted -->
            <div class="cat-purr">♥</div>
        </div>
    }
</div>

@code {
    private enum CatState { Walking, Sitting, Grooming, Sleeping }

    private record Palette(string Body, string Ear, string Eye, string Heart, string Glow);

    private class Cat
    {
        public double X, Y;
        public double Theta;
        public double TargetTheta;
        public int Facing = 1;
        public CatState State = CatState.Walking;
        public int FramesInState;
        public int HappyFrames;      // > 0 while purring
        public Palette Colors = default!;
        public Random Rng = new();
        public bool Happy => HappyFrames > 0;
    }

    // Two cats with distinct palettes: a cool teal one and a warm amber one.
    private static readonly Palette CoolPalette =
        new("#2a2d4a", "#3c4066", "#55efc4", "#ff7eb3", "rgba(85,239,196,0.4)");
    private static readonly Palette WarmPalette =
        new("#4a2e24", "#6b4636", "#ffd166", "#ff6b6b", "rgba(255,209,102,0.4)");

    private readonly List<Cat> _cats = new();

    // World (viewport) bounds.
    private double _width = 1280;
    private double _height = 720;
    private bool _reducedMotion;

    // Shared Follow-mode input.
    private bool _isFollowing;
    private double _mouseX, _mouseY;

    private const double Speed = 1.1;    // px per frame — a slow, cozy stroll
    private const int FrameMs = 66;      // ~15 fps: smooth enough, easy on battery
    private const double Fps = 1000.0 / FrameMs;
    private const int Margin = 70;       // keep cats off the very edges

    private PeriodicTimer? _timer;
    private CancellationTokenSource? _cts;
    private IJSObjectReference? _module;
    private DotNetObjectReference<CatCompanion>? _selfRef;

    private static string Px(double v) =>
        v.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture) + "px";

    private static string PaletteVars(Cat c) =>
        $" --cat-body:{c.Colors.Body}; --cat-ear:{c.Colors.Ear}; --cat-eye:{c.Colors.Eye};" +
        $" --cat-heart:{c.Colors.Heart}; --cat-glow:{c.Colors.Glow};";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/catCompanion.js");
        _selfRef = DotNetObjectReference.Create(this);
        var vp = await _module.InvokeAsync<Viewport>("init", _selfRef);
        _width = vp.Width;
        _height = vp.Height;
        _reducedMotion = vp.ReducedMotion;

        SpawnCat(CoolPalette, _width * 0.25, _height * 0.62);
        SpawnCat(WarmPalette, _width * 0.72, _height * 0.40);
        StateHasChanged();

        _cts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromMilliseconds(FrameMs));
        _ = RunLoopAsync(_cts.Token);
    }

    private void SpawnCat(Palette colors, double x, double y)
    {
        var cat = new Cat { Colors = colors, X = x, Y = y, Theta = new Random().NextDouble() * Math.PI * 2 };
        _cats.Add(cat);
        PickNewBehavior(cat);
    }

    private async Task RunLoopAsync(CancellationToken token)
    {
        try
        {
            while (await _timer!.WaitForNextTickAsync(token))
            {
                foreach (var cat in _cats) UpdateCat(cat);
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { /* shutting down */ }
    }

    private void UpdateCat(Cat c)
    {
        if (c.HappyFrames > 0) c.HappyFrames--;

        // Follow mode overrides the random walk for every cat.
        if (_isFollowing)
        {
            c.State = CatState.Walking;
            var dx = _mouseX - c.X;
            var dy = _mouseY - c.Y;
            var dist = Math.Sqrt(dx * dx + dy * dy);
            if (dist > 18)
            {
                c.TargetTheta = Math.Atan2(dy, dx);
                var speed = Speed * 1.7;            // a touch faster when chasing
                if (dist < 60) speed *= dist / 60;  // ease in near the cursor
                SteerAndMove(c, speed);
            }
            return;
        }

        if (--c.FramesInState <= 0) PickNewBehavior(c);

        if (c.State == CatState.Walking)
        {
            c.TargetTheta += (c.Rng.NextDouble() - 0.5) * 0.35;

            if (c.X < Margin) c.TargetTheta = 0;
            else if (c.X > _width - Margin) c.TargetTheta = Math.PI;
            if (c.Y < Margin) c.TargetTheta = Math.PI / 2;
            else if (c.Y > _height - Margin) c.TargetTheta = -Math.PI / 2;

            SteerAndMove(c, Speed);
        }
    }

    private void SteerAndMove(Cat c, double speed)
    {
        // Smoothly interpolate heading toward the target.
        var diff = c.TargetTheta - c.Theta;
        while (diff < -Math.PI) diff += Math.PI * 2;
        while (diff > Math.PI) diff -= Math.PI * 2;
        c.Theta += diff * 0.12;

        c.X += Math.Cos(c.Theta) * speed;
        c.Y += Math.Sin(c.Theta) * speed;
        c.X = Math.Clamp(c.X, 10, Math.Max(10, _width - 10));
        c.Y = Math.Clamp(c.Y, 10, Math.Max(10, _height - 10));

        // Face the direction of travel.
        if (Math.Cos(c.Theta) > 0.05) c.Facing = 1;
        else if (Math.Cos(c.Theta) < -0.05) c.Facing = -1;
    }

    private void PickNewBehavior(Cat c)
    {
        CatState next;
        if (_reducedMotion)
        {
            next = c.Rng.NextDouble() < 0.6 ? CatState.Sleeping : CatState.Sitting;
        }
        else
        {
            var r = c.Rng.NextDouble();
            next = r switch
            {
                < 0.50 => CatState.Walking,
                < 0.70 => CatState.Sitting,
                < 0.85 => CatState.Grooming,
                _ => CatState.Sleeping,
            };
        }

        c.State = next;
        double seconds = next switch
        {
            CatState.Walking => 3 + c.Rng.NextDouble() * 5,
            CatState.Sitting => 2 + c.Rng.NextDouble() * 3,
            CatState.Grooming => 2 + c.Rng.NextDouble() * 2,
            CatState.Sleeping => 5 + c.Rng.NextDouble() * 6,
            _ => 3,
        };
        c.FramesInState = (int)(seconds * Fps);

        if (next == CatState.Walking)
        {
            c.TargetTheta = c.Rng.NextDouble() * Math.PI * 2;
        }
    }

    private void Pet(Cat c)
    {
        c.HappyFrames = (int)(1.3 * Fps);
        // Wake a sleeping cat so it can show its happy eyes.
        if (c.State == CatState.Sleeping)
        {
            c.State = CatState.Sitting;
            c.FramesInState = (int)(2.5 * Fps);
        }
    }

    [JSInvokable]
    public Task OnPointerDown(double x, double y)
    {
        _isFollowing = true;
        _mouseX = x;
        _mouseY = y;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnPointerMove(double x, double y)
    {
        if (_isFollowing) { _mouseX = x; _mouseY = y; }
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnPointerUp()
    {
        _isFollowing = false;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnViewportResized(double width, double height)
    {
        _width = width;
        _height = height;
        foreach (var c in _cats)
        {
            c.X = Math.Clamp(c.X, Margin, Math.Max(Margin, _width - Margin));
            c.Y = Math.Clamp(c.Y, Margin, Math.Max(Margin, _height - Margin));
        }
        return Task.CompletedTask;
    }

    private record Viewport(double Width, double Height, bool ReducedMotion);

    public async ValueTask DisposeAsync()
    {
        _cts?.Cancel();
        _timer?.Dispose();
        try
        {
            if (_module is not null)
            {
                await _module.InvokeVoidAsync("dispose");
                await _module.DisposeAsync();
            }
        }
        catch (JSDisconnectedException) { /* page unloading */ }
        _selfRef?.Dispose();
        _cts?.Dispose();
    }
}
