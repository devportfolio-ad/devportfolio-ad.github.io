@page "/not-found"
@layout MainLayout

<PageTitle>Lost — @AppConfig.StudioName</PageTitle>

<section class="section" style="text-align:center; padding-top:48px;">
    <p class="eyebrow">404</p>
    <h1 class="section-title" style="font-size:clamp(2rem,6vw,3.4rem);">This page wandered off 🐾</h1>
    <p class="section-lead" style="margin:0 auto 28px;">
        The cat couldn't find what you were looking for. Let's head back somewhere cozy.
    </p>
    <a class="btn btn-primary" href="">Return home →</a>
</section>
